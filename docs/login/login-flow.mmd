flowchart TD
    Start([使用者在 /login 頁]) --> ClickGoogle["點擊 Google 登入按鈕"]
    ClickGoogle --> SignIn["auth.signInWithGoogle()<br/>呼叫 signInWithOAuth"]
    SignIn --> GoogleAuth{{"導向 Google 授權頁"}}

    GoogleAuth -->|使用者同意| CallbackOK["導回 /auth/callback?code=xxx"]
    GoogleAuth -->|使用者取消| CallbackErr["導回 /auth/callback?error=access_denied"]

    subgraph BG["背景機制（Supabase Client）"]
        direction TB
        Guard["boot/auth.ts guard<br/>放行 /auth/callback（在 PUBLIC_ROUTES）"]
        AutoExchange["detectSessionInUrl: true<br/>自動用 code 換 session<br/>（唯一的 exchange，callback 頁不手動換）"]
        Guard --> AutoExchange
    end

    CallbackOK --> Guard
    CallbackErr --> ShowErrCancelled["顯示錯誤：<br/>「你取消了授權」"]

    AutoExchange --> Waiting["AuthCallbackPage<br/>watch([isSignedIn, isReady])<br/>畫面顯示「正在完成登入」<br/>逾時 8s"]

    Waiting --> CheckSignedIn{"isSignedIn？"}
    CheckSignedIn -->|是，換成功| Redirect["router.replace('/')<br/>SPA 無重載"]
    Redirect --> MonthView(["落月曆視圖 MonthView"])

    CheckSignedIn -->|否| CheckReadyOrTimeout{"isReady 或已逾時？"}
    CheckReadyOrTimeout -->|否，繼續等| Waiting
    CheckReadyOrTimeout -->|是| ShowErrGeneric["顯示錯誤畫面 +<br/>「回到登入頁」按鈕"]

    ShowErrGeneric --> BackToLogin["點擊「回到登入頁」"]
    ShowErrCancelled --> BackToLogin
    BackToLogin --> LoginRedirect["router.replace('/login')"]
    LoginRedirect --> Start

    classDef success fill:#d4f4dd,stroke:#2e7d32,color:#1b5e20,stroke-width:1.5px;
    classDef failure fill:#fde0e0,stroke:#c62828,color:#8e0000,stroke-width:1.5px;
    classDef background fill:#e3e8f5,stroke:#3949ab,color:#1a237e,stroke-width:1.5px,stroke-dasharray: 4 3;
    classDef waiting fill:#fff8e1,stroke:#f9a825,color:#7a5c00,stroke-width:1.5px;

    class Redirect,MonthView success;
    class CallbackErr,ShowErrCancelled,ShowErrGeneric,CheckReadyOrTimeout failure;
    class Guard,AutoExchange background;
    class Waiting,CheckSignedIn waiting;
